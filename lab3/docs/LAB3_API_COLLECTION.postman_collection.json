  "item": [
    {
      "name": "01 GET claims list (filters)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/claims?status=сформирован&formed_from=2026-03-01&formed_to=2026-03-31",
          "host": ["{{base_url}}"],
          "path": ["claims"],
          "query": [
            {"key": "status", "value": "сформирован"},
            {"key": "formed_from", "value": "2026-03-01"},
            {"key": "formed_to", "value": "2026-03-31"}
          ]
        }
      }
    },
    {
      "name": "02 GET cart icon",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/claims/cart-icon",
          "host": ["{{base_url}}"],
          "path": ["claims", "cart-icon"]
        }
      }
    },
    {
      "name": "03 DELETE draft claim (if exists)",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/claims/{{draft_claim_id}}",
          "host": ["{{base_url}}"],
          "path": ["claims", "{{draft_claim_id}}"]
        }
      }
    },
    {
      "name": "04 GET services list (filter)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/services?q=brass",
          "host": ["{{base_url}}"],
          "path": ["services"],
          "query": [{"key": "q", "value": "brass"}]
        }
      }
    },
    {
      "name": "05 POST create service (image+video)",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            {"key": "name", "value": "Bronze Demo Service", "type": "text"},
            {"key": "description", "value": "Created from Postman collection for lab 3.", "type": "text"},
            {"key": "era", "value": "X-XI centuries", "type": "text"},
            {"key": "culture", "value": "Demo culture", "type": "text"},
            {"key": "unit_price", "value": "1500", "type": "text"},
            {"key": "cu_reference", "value": "0.810", "type": "text"},
            {"key": "zn_reference", "value": "0.120", "type": "text"},
            {"key": "sn_reference", "value": "0.050", "type": "text"},
            {"key": "pb_reference", "value": "0.020", "type": "text"},
            {"key": "image", "type": "file", "src": "<path-to-image-file>"},
            {"key": "video", "type": "file", "src": "<path-to-video-file>"}
          ]
        },
        "url": {
          "raw": "{{base_url}}/services",
          "host": ["{{base_url}}"],
          "path": ["services"]
        }
      }
    },
    {
