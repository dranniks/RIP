          "mode": "raw",
          "raw": "{\n  \"service_id\": {{service_id_1}}\n}"
        },
        "url": {
          "raw": "{{base_url}}/claim-items",
          "host": ["{{base_url}}"],
          "path": ["claim-items"]
        }
